<script>
document.addEventListener('DOMContentLoaded', function() {
    // Seleciona todos os elementos com a nossa classe CSS
    const todosOsTextos = document.querySelectorAll('.texto-com-leia-mais');

    todosOsTextos.forEach(textoContainer => {
        // Define a quantidade máxima de caracteres que você quer exibir
        const maxCaracteres = 300; // Altere este valor como desejar

        // Pega o conteúdo original completo e o texto truncado
        const conteudoOriginal = textoContainer.innerHTML;
        const conteudoTruncado = textoContainer.innerText.substring(0, maxCaracteres);
        
        // Verifica se o texto realmente precisa do botão "Leia mais"
        if (textoContainer.innerText.length > maxCaracteres) {
            
            // Inicia com o conteúdo truncado e a classe 'recolhido'
            textoContainer.innerHTML = conteudoTruncado + '...';
            textoContainer.classList.add('recolhido');

            // Cria o botão "Leia mais"
            const btn = document.createElement('button');
            btn.innerText = 'Leia mais';
            btn.className = 'btn-leia-mais';

            // Insere o botão logo após o container de texto
            textoContainer.parentNode.insertBefore(btn, textoContainer.nextSibling);

            // Adiciona a funcionalidade de clique ao botão
            btn.addEventListener('click', function() {
                // Verifica se o texto está recolhido
                if (textoContainer.classList.contains('recolhido')) {
                    textoContainer.innerHTML = conteudoOriginal;
                    textoContainer.classList.remove('recolhido');
                    btn.innerText = 'Leia menos';
                } else {
                    textoContainer.innerHTML = conteudoTruncado + '...';
                    textoContainer.classList.add('recolhido');
                    btn.innerText = 'Leia mais';
                }
            });
        }
    });
});
</script>
<style>
.fjp-sc-toolbar {
  background: #ffffff !important;
  border-bottom: 1px solid #dfe3e8 !important;
}

.fjp-sc-toolbar-inner {
  max-width: 1280px;
  padding: 12px 16px;
  gap: 10px;
  align-items: center;
}

.fjp-sc-toolbar a {
  display: inline-flex;
  align-items: center;
  min-height: 40px;
  padding: 0 14px;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 600;
  text-decoration: none;
  color: #5f1520;
}

.fjp-sc-toolbar a:hover,
.fjp-sc-toolbar a:focus-visible {
  background: #f4f5f7;
  border-color: #d8dce2;
  color: #8b1521;
  outline: none;
}

.fjp-sc-contrast-toggle {
  position: relative;
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  padding: 0 !important;
  margin-left: auto;
  border: 1px solid #cfd4dc !important;
  border-radius: 999px;
  background: #ffffff !important;
  color: transparent !important;
  font-size: 0 !important;
  line-height: 1 !important;
  text-decoration: none !important;
  overflow: hidden;
}

.fjp-sc-contrast-toggle::before {
  content: '';
  width: 18px;
  height: 18px;
  border-radius: 999px;
  border: 2px solid #5f1520;
  background: linear-gradient(90deg, #5f1520 0 50%, transparent 50% 100%);
  box-sizing: border-box;
}

.fjp-sc-contrast-toggle:hover,
.fjp-sc-contrast-toggle:focus-visible {
  background: #f4f5f7 !important;
  border-color: #8b1521 !important;
  outline: none;
  box-shadow: 0 0 0 3px rgba(139, 21, 33, 0.15);
}

.fjp-sc-contrast-toggle[aria-pressed="true"] {
  background: #111111 !important;
  border-color: #111111 !important;
}

.fjp-sc-contrast-toggle[aria-pressed="true"]::before {
  border-color: #ffffff;
  background: linear-gradient(90deg, #ffffff 0 50%, transparent 50% 100%);
}

.fjp-sc-sitemap,
.fjp-sc-accessibility-page {
  max-width: none;
  width: 100%;
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.fjp-sc-sitemap > h2,
.fjp-sc-accessibility-page > h2 {
  margin: 0 0 14px;
  color: #5f1520;
  font-size: clamp(1.75rem, 3vw, 2.35rem);
  line-height: 1.1;
}

.fjp-sc-sitemap > p,
.fjp-sc-accessibility-page > p {
  margin: 0 0 24px;
  color: #4b5563;
  font-size: 1.05rem;
  line-height: 1.7;
}

.fjp-sc-sitemap-list,
.fjp-sc-sitemap-list ul {
  list-style: none;
  margin: 0;
  padding-left: 0;
}

.fjp-sc-sitemap-list > li {
  margin-bottom: 14px;
}

.fjp-sc-sitemap-list > li > a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
  color: #5f1520;
}

.fjp-sc-sitemap-list ul {
  margin-top: 10px;
  padding-left: 18px;
  border-left: 2px solid #d7dce2;
}

.fjp-sc-sitemap-list a {
  text-decoration: none;
}

.fjp-sc-sitemap-list a:hover,
.fjp-sc-sitemap-list a:focus-visible {
  color: #8b1521;
  text-decoration: underline;
}

.fjp-sc-accessibility-page h3 {
  margin: 32px 0 14px;
  font-size: 1.15rem;
  color: #5f1520;
}

.fjp-sc-accessibility-page ul {
  margin: 0;
  padding-left: 20px;
  color: #1f2937;
}

.fjp-sc-accessibility-page li + li {
  margin-top: 8px;
}

.fjp-sc-accessibility-actions {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin: 24px 0 30px;
  padding: 16px 18px;
  background: #f7f8fa;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
}

.fjp-sc-action-button {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-height: 44px;
  padding: 0 16px;
  border: 0;
  border-radius: 999px;
  background: #8b1521;
  color: #ffffff;
  font: inherit;
  font-weight: 700;
  cursor: pointer;
}

.fjp-sc-action-button svg {
  width: 18px;
  height: 18px;
  flex: none;
}

.fjp-sc-action-button:hover,
.fjp-sc-action-button:focus-visible {
  background: #6f101a;
  outline: none;
  box-shadow: 0 0 0 3px rgba(139, 21, 33, 0.15);
}

.fjp-sc-accessibility-helper {
  margin: 0;
  color: #4b5563;
  line-height: 1.6;
}

.fjp-sc-visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}

body.fjp-high-contrast,
body.fjp-high-contrast .site,
body.fjp-high-contrast .site-content,
body.fjp-high-contrast .site-main {
  background: #000000 !important;
  color: #ffffff !important;
}

body.fjp-high-contrast .elementor-background-overlay,
body.fjp-high-contrast .elementor-background-video-container,
body.fjp-high-contrast .elementor-motion-effects-container,
body.fjp-high-contrast .elementor-background-slideshow {
  display: none !important;
}

body.fjp-high-contrast .e-con,
body.fjp-high-contrast .elementor-section,
body.fjp-high-contrast .elementor-column,
body.fjp-high-contrast .elementor-widget-wrap,
body.fjp-high-contrast .elementor-widget-container,
body.fjp-high-contrast section,
body.fjp-high-contrast article,
body.fjp-high-contrast aside,
body.fjp-high-contrast header,
body.fjp-high-contrast footer,
body.fjp-high-contrast nav,
body.fjp-high-contrast main,
body.fjp-high-contrast form,
body.fjp-high-contrast div {
  background: transparent !important;
  background-image: none !important;
  box-shadow: none !important;
}

body.fjp-high-contrast,
body.fjp-high-contrast p,
body.fjp-high-contrast li,
body.fjp-high-contrast span,
body.fjp-high-contrast strong,
body.fjp-high-contrast em,
body.fjp-high-contrast small,
body.fjp-high-contrast label,
body.fjp-high-contrast h1,
body.fjp-high-contrast h2,
body.fjp-high-contrast h3,
body.fjp-high-contrast h4,
body.fjp-high-contrast h5,
body.fjp-high-contrast h6 {
  color: #ffffff !important;
}

body.fjp-high-contrast a {
  color: #ffeb3b !important;
  text-decoration: underline !important;
}

body.fjp-high-contrast button,
body.fjp-high-contrast input,
body.fjp-high-contrast select,
body.fjp-high-contrast textarea {
  background: #000000 !important;
  color: #ffffff !important;
  border: 2px solid #ffffff !important;
}

body.fjp-high-contrast *:focus-visible {
  outline: 3px solid #ffeb3b !important;
  outline-offset: 2px !important;
}

body.fjp-high-contrast .fjp-sc-toolbar {
  background: #000000 !important;
  border-color: #ffffff !important;
}

body.fjp-high-contrast .fjp-sc-toolbar a {
  color: #ffffff !important;
  border-color: #ffffff !important;
  background: #000000 !important;
}

body.fjp-high-contrast .fjp-sc-contrast-toggle {
  background: #ffffff !important;
  border-color: #ffffff !important;
}

body.fjp-high-contrast .fjp-sc-sitemap,
body.fjp-high-contrast .fjp-sc-accessibility-page,
body.fjp-high-contrast .fjp-sc-accessibility-actions {
  border-color: #ffffff !important;
  background: #000000 !important;
  box-shadow: none !important;
}

body.fjp-high-contrast .fjp-sc-action-button {
  background: #ffffff !important;
  color: #000000 !important;
  border: 2px solid #ffffff !important;
}

@media (max-width: 767px) {
  .fjp-sc-toolbar-inner {
    gap: 8px;
  }

  .fjp-sc-toolbar a {
    min-height: 36px;
    padding: 0 12px;
  }

  .fjp-sc-contrast-toggle {
    width: 36px;
    height: 36px;
    margin-left: 0;
  }

  .fjp-sc-accessibility-actions {
    align-items: stretch;
  }
}
</style>
<script>
(function () {
  var storageKey = 'fjp_sc_high_contrast';

  function readSavedState() {
    try {
      return window.localStorage.getItem(storageKey) === '1';
    } catch (error) {
      return document.body.classList.contains('fjp-high-contrast');
    }
  }

  function saveState(enabled) {
    try {
      window.localStorage.setItem(storageKey, enabled ? '1' : '0');
    } catch (error) {
      return;
    }
  }

  function updateButtons(enabled) {
    document.querySelectorAll('[data-fjp-contrast-control]').forEach(function (button) {
      button.setAttribute('aria-pressed', enabled ? 'true' : 'false');
      if (button.dataset.buttonType === 'page') {
        var label = button.querySelector('.fjp-sc-button-label');
        if (label) {
          label.textContent = enabled ? 'Desativar alto contraste' : 'Ativar alto contraste';
        }
      }
    });
  }

  function applyContrast(enabled) {
    document.body.classList.toggle('fjp-high-contrast', enabled);
    document.documentElement.classList.toggle('fjp-high-contrast', enabled);
    updateButtons(enabled);
  }

  function handleToggle(event) {
    if (event) {
      event.preventDefault();
      event.stopImmediatePropagation();
    }

    var enabled = !document.body.classList.contains('fjp-high-contrast');
    applyContrast(enabled);
    saveState(enabled);
  }

  function enhanceToolbarButton() {
    var button = document.querySelector('.fjp-sc-contrast-toggle');
    if (!button) {
      return;
    }

    button.setAttribute('type', 'button');
    button.setAttribute('title', 'Alternar alto contraste');
    button.setAttribute('aria-label', 'Alternar alto contraste');
    button.setAttribute('data-fjp-contrast-control', '1');
    button.dataset.buttonType = 'toolbar';

    if (!button.querySelector('.fjp-sc-visually-hidden')) {
      var helper = document.createElement('span');
      helper.className = 'fjp-sc-visually-hidden';
      helper.textContent = 'Alternar alto contraste';
      button.appendChild(helper);
    }

    if (button.dataset.fjpBound !== '1') {
      button.dataset.fjpBound = '1';
      button.addEventListener('click', handleToggle, true);
    }
  }

  function injectAccessibilityControls() {
    var page = document.querySelector('.fjp-sc-accessibility-page');
    if (!page || page.querySelector('.fjp-sc-accessibility-actions')) {
      return;
    }

    var actions = document.createElement('div');
    actions.className = 'fjp-sc-accessibility-actions';
    actions.innerHTML = '<button type="button" class="fjp-sc-action-button" data-fjp-contrast-control="1" data-button-type="page" aria-pressed="false"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.8"></circle><path d="M12 4a8 8 0 0 1 0 16z" fill="currentColor"></path></svg><span class="fjp-sc-button-label">Ativar alto contraste</span></button><p class="fjp-sc-accessibility-helper">Use este botão para alternar o modo de alto contraste com efeito imediato em todo o portal.</p>';

    var intro = page.querySelector('p');
    if (intro) {
      intro.insertAdjacentElement('afterend', actions);
    } else {
      page.prepend(actions);
    }

    var pageButton = actions.querySelector('.fjp-sc-action-button');
    if (pageButton) {
      pageButton.addEventListener('click', handleToggle);
    }
  }

  function ensureMainId() {
    var mainTarget = document.querySelector('main, #main, #content, .site-main');
    if (mainTarget && !mainTarget.id) {
      mainTarget.id = 'conteudo-principal';
    }
  }

  function init() {
    ensureMainId();
    enhanceToolbarButton();
    injectAccessibilityControls();
    applyContrast(readSavedState());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


</body>
</html>


