/* Start custom CSS for container, class: .elementor-element-27faf90 *//* Transições suaves */
.icone,
.icone * , /* isso cobre os filhos como <svg> */
.texto {
  transition: all 0.4s ease-in-out;
}

/* Hover no container */
.hover-container:hover .icone,
.hover-container:hover .icone * {
  color: #fff;
  fill: #fff;
}

/* Texto com movimento e escala */
.hover-container:hover .texto {
