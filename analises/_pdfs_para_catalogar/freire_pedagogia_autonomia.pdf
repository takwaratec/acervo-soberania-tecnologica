</td>
</tr>
<tr class="row-0">
<td>context:/jndi:/localhost/sitemap.xmap - 278:60</td>
<td>
<em>&lt;map:select type="browser"&gt;</em>
</td>
</tr>
<tr class="row-1">
<td>context:/jndi:/localhost/sitemap.xmap - 257:70</td>
<td>
<em>&lt;map:match&gt;</em>
</td>
</tr>
</table>
<br />
</div>
